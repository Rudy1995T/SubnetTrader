# EMA-only environment configuration

# FlameWire RPC
FLAMEWIRE_API_KEY=
FLAMEWIRE_CHAIN=bittensor
FLAMEWIRE_TIMEOUT=30.0
FLAMEWIRE_RETRIES=3
FLAMEWIRE_RETRY_DELAY=2.0
FLAMEWIRE_WS_PING_INTERVAL=20.0
FLAMEWIRE_WS_RECONNECT_DELAY=5.0

# Subtensor fallback (used when FlameWire is unreachable)
SUBTENSOR_FALLBACK_NETWORK=wss://entrypoint-finney.opentensor.ai:443

# Taostats
TAOSTATS_API_KEY=
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_RATE_LIMIT_PER_MIN=30
TAOSTATS_CACHE_TTL_SEC=300

# Wallet
BT_WALLET_NAME=SN_Bot
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets
BT_WALLET_PASSWORD=

# Scheduler
SCAN_INTERVAL_MIN=15

# Execution
MAX_ENTRY_PRICE_TAO=0.1
MAX_SLIPPAGE_PCT=5.0

# EMA Strategy A — Scalper (fast=3, slow=9)
EMA_ENABLED=true
EMA_DRY_RUN=true
EMA_DRY_RUN_STARTING_TAO=2.0
EMA_STRATEGY_TAG=scalper
EMA_PERIOD=9
EMA_FAST_PERIOD=3
EMA_CONFIRM_BARS=3
EMA_POT_TAO=5.0
EMA_POSITION_SIZE_PCT=0.33
EMA_MAX_POSITIONS=3
EMA_STOP_LOSS_PCT=8.0
EMA_TAKE_PROFIT_PCT=20.0
EMA_MAX_HOLDING_HOURS=168
EMA_COOLDOWN_HOURS=4.0
EMA_DRAWDOWN_BREAKER_PCT=15.0
EMA_DRAWDOWN_PAUSE_HOURS=6.0
EMA_EXIT_WATCHER_ENABLED=true
EMA_EXIT_WATCHER_SEC=15
EMA_CORRELATION_THRESHOLD=0.80
EMA_CANDLE_TIMEFRAME_HOURS=4
EMA_BOUNCE_ENABLED=true
EMA_BOUNCE_TOUCH_TOLERANCE_PCT=1.0
EMA_BOUNCE_REQUIRE_GREEN=true
EMA_MAX_GINI=0.82

# EMA Strategy B — Trend (fast=3, slow=18)
EMA_B_ENABLED=true
EMA_B_DRY_RUN=true
EMA_B_STRATEGY_TAG=trend
EMA_B_PERIOD=18
EMA_B_FAST_PERIOD=3
EMA_B_CONFIRM_BARS=3
EMA_B_POT_TAO=5.0
EMA_B_POSITION_SIZE_PCT=0.33
EMA_B_MAX_POSITIONS=3
EMA_B_STOP_LOSS_PCT=8.0
EMA_B_TAKE_PROFIT_PCT=20.0
EMA_B_MAX_HOLDING_HOURS=168
EMA_B_COOLDOWN_HOURS=4.0
EMA_B_DRAWDOWN_BREAKER_PCT=15.0
EMA_B_DRAWDOWN_PAUSE_HOURS=6.0
EMA_B_CORRELATION_THRESHOLD=0.80
EMA_B_CANDLE_TIMEFRAME_HOURS=4
EMA_B_BREAKEVEN_TRIGGER_PCT=3.0
EMA_B_TRAILING_STOP_PCT=5.0
EMA_B_BOUNCE_ENABLED=true
EMA_B_BOUNCE_TOUCH_TOLERANCE_PCT=1.0
EMA_B_BOUNCE_REQUIRE_GREEN=true
EMA_B_MAX_GINI=0.82

# Telegram alerts + commands (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Observability
LOG_LEVEL=INFO
DB_PATH=data/ledger.db
JSONL_DIR=data/logs
HEALTH_PORT=8081
KILL_SWITCH_PATH=./KILL_SWITCH
