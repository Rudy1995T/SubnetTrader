# ═══════════════════════════════════════════════════════════════
# Bittensor Subnet Alpha Trading Bot – Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────────────────────────
# Set to false for LIVE trading (real on-chain transactions)
DRY_RUN=true

# ── FlameWire RPC ─────────────────────────────────────────────
FLAMEWIRE_API_KEY=
FLAMEWIRE_CHAIN=bittensor
# FLAMEWIRE_HTTP_TEMPLATE=https://gateway-dev.flamewire.io/public/rpc/{chain}/{api_key}
# FLAMEWIRE_WS_TEMPLATE=wss://gateway-dev.flamewire.io/public/rpc/{chain}/{api_key}
FLAMEWIRE_TIMEOUT=30.0
FLAMEWIRE_RETRIES=3

# ── Taostats API ──────────────────────────────────────────────
TAOSTATS_API_KEY=
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_RATE_LIMIT_PER_MIN=30
TAOSTATS_CACHE_TTL_SEC=300

# ── Bittensor Wallet ──────────────────────────────────────────
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets
BT_WALLET_PASSWORD=

# ── Scheduler ─────────────────────────────────────────────────
SCAN_INTERVAL_MIN=15

# ── Portfolio ─────────────────────────────────────────────────
NUM_SLOTS=4
MAX_HOLDING_HOURS=72
TARGET_HOLDING_HOURS=48
MAX_SLIPPAGE_PCT=5.0
MAX_TRADES_PER_DAY=20
COOLDOWN_HOURS=8.0
DAILY_DRAWDOWN_LIMIT_PCT=10.0
ALLOW_DOUBLE_SLOT=false

# ── Strategy ──────────────────────────────────────────────────
ENTER_THRESHOLD=0.55
HIGH_CONVICTION_THRESHOLD=0.80
STOP_LOSS_PCT=8.0
TAKE_PROFIT_PCT=15.0
TRAILING_STOP_PCT=5.0

# ── Value Band Heuristic ──────────────────────────────────────
VALUE_BAND_LOW=0.0035
VALUE_BAND_HIGH=0.0050
VALUE_BAND_DECAY=0.001

# ── Signal Weights (should sum to ~1.0) ───────────────────────
W_TREND=0.20
W_SUPPORT_RESISTANCE=0.15
W_FIBONACCI=0.15
W_VOLATILITY=0.20
W_MEAN_REVERSION=0.15
W_VALUE_BAND=0.15

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/ledger.db
JSONL_DIR=data/logs

# ── Health Endpoint ───────────────────────────────────────────
HEALTH_PORT=8080
