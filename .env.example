# EMA-only environment configuration

# Subtensor
SUBTENSOR_NETWORK=wss://entrypoint-finney.opentensor.ai:443

# Taostats
TAOSTATS_API_KEY=
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_RATE_LIMIT_PER_MIN=30
TAOSTATS_CACHE_TTL_SEC=300

# Wallet
BT_WALLET_NAME=SN_Bot
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=~/.bittensor/wallets
BT_WALLET_PASSWORD=

# Scheduler
SCAN_INTERVAL_MIN=15

# Execution
MAX_ENTRY_PRICE_TAO=0.1
MAX_SLIPPAGE_PCT=5.0

# MR Strategy A — Mean-Reversion (replaces Scalper)
MR_ENABLED=true
MR_STRATEGY_TAG=meanrev
MR_POT_TAO=5.0
MR_POSITION_SIZE_PCT=0.25
MR_MAX_POSITIONS=4
MR_STOP_LOSS_PCT=5.0
MR_TAKE_PROFIT_PCT=8.0
MR_MAX_HOLDING_HOURS=24
MR_COOLDOWN_HOURS=2.0
MR_CANDLE_TIMEFRAME_HOURS=1
MR_DRAWDOWN_BREAKER_PCT=15.0
MR_DRAWDOWN_PAUSE_HOURS=6.0
MR_CORRELATION_THRESHOLD=0.80
MR_MAX_GINI=0.82
MR_MIN_POOL_DEPTH_TAO=3000.0
# Mean-reversion signal parameters
MR_RSI_ENTRY=30.0
MR_RSI_EXIT=65.0
MR_RSI_PERIOD=14
MR_BB_PERIOD=20
MR_BB_STD=2.0
MR_BB_MID_EXIT=true
# Vol-sizing
MR_VOL_SIZING_ENABLED=true
MR_VOL_TARGET_RISK=0.02
MR_VOL_FLOOR=0.10
MR_VOL_CAP=1.50
MR_VOL_MIN_SIZE_PCT=0.15
MR_VOL_MAX_SIZE_PCT=0.40
MR_VOL_WINDOW=24

# Shared exit/entry watcher settings (used by both strategies)
EMA_EXIT_WATCHER_ENABLED=true
EMA_EXIT_WATCHER_SEC=15

# EMA Strategy B — Trend (fast=3, slow=18)
EMA_B_ENABLED=true
EMA_B_DRY_RUN=true
EMA_B_STRATEGY_TAG=trend
EMA_B_PERIOD=18
EMA_B_FAST_PERIOD=3
EMA_B_CONFIRM_BARS=3
EMA_B_POT_TAO=5.0
EMA_B_POSITION_SIZE_PCT=0.33
EMA_B_MAX_POSITIONS=3
EMA_B_STOP_LOSS_PCT=8.0
EMA_B_TAKE_PROFIT_PCT=20.0
EMA_B_MAX_HOLDING_HOURS=168
EMA_B_COOLDOWN_HOURS=4.0
EMA_B_DRAWDOWN_BREAKER_PCT=15.0
EMA_B_DRAWDOWN_PAUSE_HOURS=6.0
EMA_B_CORRELATION_THRESHOLD=0.80
EMA_B_CANDLE_TIMEFRAME_HOURS=4
EMA_B_BREAKEVEN_TRIGGER_PCT=3.0
EMA_B_TRAILING_STOP_PCT=5.0
EMA_B_BOUNCE_ENABLED=true
EMA_B_BOUNCE_TOUCH_TOLERANCE_PCT=1.0
EMA_B_BOUNCE_REQUIRE_GREEN=true
EMA_B_MAX_GINI=0.82

# HTF (higher-timeframe) confirmation — uses the deepest history the
# Taostats subnet-history endpoint returns (currently ~daily regardless of
# requested interval). Fast/slow are EMA periods in HTF bars. The gate passes
# on BUY/HOLD and only blocks on SELL. Disable the flag to fall back to the
# legacy (strict live-TF crossover) behaviour for one release.
EMA_HTF_CONFIRM_ENABLED=true
EMA_B_HTF_FAST_PERIOD=5
EMA_B_HTF_SLOW_PERIOD=20
EMA_B_HTF_CONFIRM_BARS=2
MR_HTF_FAST_PERIOD=5
MR_HTF_SLOW_PERIOD=20
MR_HTF_CONFIRM_BARS=2

# Flow Strategy C — Pool Flow Momentum (v2)
# Detects real buy-side capital inflow from pool reserve changes. Disabled by
# default so legacy deploys keep two strategies; flip FLOW_ENABLED=true to add
# a third independent pot. FLOW_DRY_RUN=true is recommended until the baseline
# has filled (~52h of 5-min snapshots).
FLOW_ENABLED=false
FLOW_DRY_RUN=true
FLOW_STRATEGY_TAG=flow
FLOW_PERSIST_SNAPSHOTS=true
FLOW_SNAPSHOT_RETENTION_HOURS=336
FLOW_SLOTS=3
FLOW_POT_TAO=10.0
FLOW_POSITION_SIZE_PCT=0.33
FLOW_MAX_POOL_IMPACT_PCT=1.5
FLOW_MIN_POOL_DEPTH_TAO=5000.0
FLOW_MAX_GINI=0.82
FLOW_CORRELATION_THRESHOLD=0.80
# Signal thresholds
FLOW_Z_ENTRY=2.0
FLOW_Z_EXIT=-1.5
FLOW_MIN_TAO_PCT=2.0
FLOW_EXIT_PCT=0.5
FLOW_MAGNITUDE_CAP=10.0
# Windows (expressed in snapshots, not hours — adapts to SCAN_INTERVAL_MIN)
FLOW_WINDOW_1H_SNAPS=12
FLOW_WINDOW_4H_SNAPS=48
FLOW_BASELINE_SNAPS=576
FLOW_COLD_START_SNAPS=624
FLOW_MAX_GAP_MIN=30
# Emission normalization — subtracts expected emission-driven TAO inflow
FLOW_EMISSION_ADJUST=true
FLOW_EMISSION_SOLD_FRACTION=0.60
# Exits
FLOW_STOP_LOSS_PCT=6.0
FLOW_TAKE_PROFIT_PCT=12.0
FLOW_TRAILING_PCT=4.0
FLOW_TRAILING_TRIGGER_PCT=3.0
FLOW_TIME_SOFT_HOURS=6
FLOW_TIME_HARD_HOURS=24
FLOW_REQUIRE_EMA_CONFIRM=true
FLOW_EMA_FAST_PERIOD=5
FLOW_EMA_SLOW_PERIOD=18
FLOW_CANDLE_TIMEFRAME_HOURS=4
FLOW_DRAWDOWN_BREAKER_PCT=15.0
FLOW_DRAWDOWN_PAUSE_HOURS=6.0
# Asymmetric cooldowns by exit reason
FLOW_COOLDOWN_STOP_HOURS=12.0
FLOW_COOLDOWN_WIN_HOURS=4.0
FLOW_COOLDOWN_TIME_HOURS=6.0
# Market-wide regime filter
FLOW_REGIME_FILTER_ENABLED=true
FLOW_REGIME_INDEX_THRESHOLD=0.95
FLOW_REGIME_LOOKBACK_SNAPS=288

# Volatility Regime Filter (meta-strategy) — gates entries across all
# strategies based on aggregate realized vol, directional strength, and
# cross-sectional dispersion. Exits are never gated. Kill-switch via
# REGIME_ENABLED=false lets classification keep logging in shadow mode.
# See specs/strategy-volatility-regime-filter.md for the state table.
REGIME_ENABLED=true
REGIME_VOL_WINDOW_HOURS=24
REGIME_VOL_TREND_THRESHOLD=0.30
REGIME_VOL_CHOP_FLOOR=0.10
REGIME_VOL_DEAD_THRESHOLD=0.05
REGIME_DIR_THRESHOLD=0.02
REGIME_DISP_THRESHOLD=0.015
REGIME_DEBOUNCE_CYCLES=2
REGIME_REFRESH_SECONDS=60
REGIME_MIN_SUBNETS=10
REGIME_MIN_BUCKETS=6
REGIME_BUCKET_HOURS=4
# Per-strategy gates — comma-separated regime names (case-insensitive) or
# the literal "all". MR intentionally inverts EMA/Flow.
# Flow: backtest showed a negative edge in TRENDING (win-rate 43%, PnL -7.5%),
# positive edge in DISPERSED — so flow is gated to DISPERSED only.
REGIME_GATE_EMA=trending,dispersed
REGIME_GATE_FLOW=dispersed
REGIME_GATE_MR=choppy,dispersed
REGIME_GATE_YIELD=all

# Telegram alerts + commands (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Observability
LOG_LEVEL=INFO
DB_PATH=data/ledger.db
JSONL_DIR=data/logs
HEALTH_PORT=8081
KILL_SWITCH_PATH=./KILL_SWITCH
